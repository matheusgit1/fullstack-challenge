{
  "name": "@crash/core",
  "version": "1.0.0",
  "author": "Matheus Alves Pereira <pereira.matheusalves@gmail.com>",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js",
      "require": "./dist/auth/index.js"
    },
    "./keycloak": {
      "types": "./dist/keycloak/index.d.ts",
      "import": "./dist/keycloak/index.js",
      "require": "./dist/keycloak/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "require": "./dist/types/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "express": "^5.2.1",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/axios": "^10.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.5"
  },
  "type": "module"
}
