{
  "name": "@crash/wallets",
  "version": "0.0.1",
  "private": true,
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "scripts": {
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "build": "bun run nest build",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "dev": "bun run --watch src/main.ts",
    "start:debug": "nest start --debug --watch",
    "start": "bun run src/main.ts",
    "test": "bun test src/**/*.spec.ts",
    "test:e2e": "bun test tests/e2e"
  },
  "dependencies": {
    "@golevelup/nestjs-rabbitmq": "^9.0.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/platform-ws": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^11.0.0",
    "amqplib": "^1.0.2",
    "cors": "^2.8.6",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@darraghor/eslint-plugin-nestjs-typed": "^7.1.28",
    "@eslint/js": "^10.0.1",
    "@nestjs/testing": "^11.1.18",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.2.0",
    "bun-types": "latest",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.0"
  }
}
